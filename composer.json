{
    "name": "letmesendemail/letmesendemail-php",
    "description": "letmesend.email PHP SDK.",
    "keywords": [
        "php",
        "letmesend",
        "letmesend-email",
        "sdk",
        "api",
        "client"
    ],
    "homepage": "https://letmesend.email/",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.5"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.13",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^1.0|^2.0|^3.0|^4.0",
        "symfony/var-dumper": "^6.0|^7.0"
    },
    "autoload": {
        "psr-4": {
            "LetMeSendEmail\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "prefer-stable": true
}
